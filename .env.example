# Practice Exam — environment variables
# Copy this file to `.env` at the project root and fill in real values.
# NEVER commit `.env` — it is listed in `.gitignore`.
#
# IMPORTANT — URL-encode your Supabase password in both URLs below.
# Special characters (@ # ! $ % & = ? etc.) break Prisma with "empty host" (P1013).
# Example: password P@ss#w!rd → P%40ss%23w%21rd
# See docs/DATABASE_URL.md for the full encoding table and a Node one-liner.

# Supabase PostgreSQL — transaction pooler (runtime queries via Prisma)
# Use port 6543 with pgbouncer for NestJS API / Prisma Client
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:P%40ssw%23rd@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase PostgreSQL — session pooler (migrations only)
# Use port 5432 for `prisma migrate` and `prisma db push` (directUrl in schema.prisma)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:P%40ssw%23rd@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT — API token signing (generate strong secrets for production)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"

# Google OAuth (web sign-in W-01)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# Zalo OAuth (Mini App Z-01, link flows W-51/Z-51)
ZALO_APP_ID=""
ZALO_APP_SECRET=""

# Web app URL (OAuth redirect targets)
WEB_APP_URL="http://localhost:3000"

# Admin app URL (local dev default port 3002)
ADMIN_APP_URL="http://localhost:3002"

# Comma-separated browser origins allowed to call the API (overrides defaults when set).
# When unset in development, localhost plus private LAN IPs on ports 3000/3002/3003 are allowed.
# CORS_ORIGINS="http://localhost:3000,http://localhost:3002,http://192.168.56.1:3002,https://your-production-domain.com"

# Public API URL for client apps
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Admin back-office seed account (A-01) — created by `pnpm --filter @practice-exam/api prisma:seed`
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="Admin@123"

# Payments (AD-5 PayOS/SePay — mock adapters used when credentials unset)
DEFAULT_PAYMENT_PROVIDER="payos"
API_PUBLIC_URL="http://localhost:3001"
